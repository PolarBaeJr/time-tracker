# WorkTracker Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials!

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase project URL
# Find this in your Supabase Dashboard > Settings > API
# Example: https://your-project-id.supabase.co
SUPABASE_URL=

# Supabase anonymous (public) key
# Find this in your Supabase Dashboard > Settings > API
# This key is safe for client-side use - it's protected by RLS policies
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=

# Supabase service role key
# SERVER ONLY. Required for admin-only scripts such as `npm run seed:dev`.
# Never expose this key in the mobile app, web bundle, or committed source code.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# OAUTH CONFIGURATION (configured in Supabase Dashboard)
# =============================================================================
# Google OAuth client ID
# Create this in Google Auth Platform / Google Cloud Console.
# For hosted Supabase, paste the same value into
# Supabase Dashboard > Authentication > Providers > Google.
# For local Supabase CLI, supabase/config.toml reads this from .env.
GOOGLE_CLIENT_ID=

# Google OAuth client secret
# Keep this secret out of git. For hosted Supabase, paste it into the
# Google provider settings in the Supabase Dashboard.
# For local Supabase CLI, supabase/config.toml reads this from .env.
GOOGLE_CLIENT_SECRET=

# Reversed iOS client ID used by Expo build config for native Google sign-in.
# Example: com.googleusercontent.apps.1234567890-abcdefghijklmnopqrstuvwxyz
GOOGLE_IOS_REVERSED_CLIENT_ID=

# Mobile deep link used after Supabase finishes the OAuth callback flow.
# This is NOT a Google redirect URI; it belongs in Supabase redirect allow-lists.
# WORKTRACKER_OAUTH_REDIRECT_URI=worktracker://auth/callback

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# Expo Application Services project ID used by app.config.js at build time.
EAS_PROJECT_ID=

# =============================================================================
# OPTIONAL: DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug logging (optional)
# DEBUG=true

# =============================================================================
# DOCKER / DEPLOYMENT
# =============================================================================

# Host port published by docker-compose for the web container.
WORKTRACKER_WEB_PORT=3000

# Host port published by docker-compose.prod.yml.
WORKTRACKER_HTTP_PORT=80

# Optional image tag for production compose deployments.
WORKTRACKER_IMAGE=worktracker-web:latest

# Target platform for production builds, useful for Raspberry Pi deployments.
WORKTRACKER_DOCKER_PLATFORM=linux/arm64

# Docker log rotation settings used by docker-compose.prod.yml.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILES=3

# Optional port for the compose-managed Supabase profile.
SUPABASE_LOCAL_PORT=54321

# =============================================================================
# EMAIL & CALENDAR OAUTH (Gmail, Outlook)
# =============================================================================

# Google OAuth Client ID for Gmail and Google Calendar
# Create this in Google Cloud Console > APIs & Services > Credentials
# Required scopes: Gmail (gmail.readonly, userinfo.email), Calendar (calendar.readonly)
# This is the SAME client ID as GOOGLE_CLIENT_ID above, but used for email/calendar APIs
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Microsoft OAuth Client ID for Outlook Email and Calendar
# Create this in Azure Portal > App registrations > New registration
# Required scopes: Mail.Read, Calendars.Read, User.Read, offline_access
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=

# =============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# =============================================================================

# Encryption key for storing OAuth tokens securely in the database
# Generate with: openssl rand -base64 32
# Set in Supabase: supabase secrets set ENCRYPTION_KEY="your-key"
# ENCRYPTION_KEY=

# Google Client ID for Edge Functions (server-side token refresh)
# Same as EXPO_PUBLIC_GOOGLE_CLIENT_ID, but set as Supabase secret
# Set in Supabase: supabase secrets set GOOGLE_CLIENT_ID="your-client-id"
# GOOGLE_CLIENT_ID=

# Microsoft Client ID for Edge Functions (server-side token refresh)
# Same as EXPO_PUBLIC_MICROSOFT_CLIENT_ID, but set as Supabase secret
# Set in Supabase: supabase secrets set MICROSOFT_CLIENT_ID="your-client-id"
# MICROSOFT_CLIENT_ID=
