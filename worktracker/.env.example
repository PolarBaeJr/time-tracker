# WorkTracker Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials!

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase project URL
# Find this in your Supabase Dashboard > Settings > API
# Example: https://your-project-id.supabase.co
SUPABASE_URL=

# Supabase anonymous (public) key
# Find this in your Supabase Dashboard > Settings > API
# This key is safe for client-side use - it's protected by RLS policies
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=

# =============================================================================
# OAUTH CONFIGURATION (configured in Supabase Dashboard)
# =============================================================================
# Google OAuth client ID
# Create this in Google Auth Platform / Google Cloud Console.
# For hosted Supabase, paste the same value into
# Supabase Dashboard > Authentication > Providers > Google.
# For local Supabase CLI, supabase/config.toml reads this from .env.
GOOGLE_CLIENT_ID=

# Google OAuth client secret
# Keep this secret out of git. For hosted Supabase, paste it into the
# Google provider settings in the Supabase Dashboard.
# For local Supabase CLI, supabase/config.toml reads this from .env.
GOOGLE_CLIENT_SECRET=

# Mobile deep link used after Supabase finishes the OAuth callback flow.
# This is NOT a Google redirect URI; it belongs in Supabase redirect allow-lists.
# WORKTRACKER_OAUTH_REDIRECT_URI=worktracker://auth/callback

# =============================================================================
# OPTIONAL: DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug logging (optional)
# DEBUG=true
