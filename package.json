{
  "name": "worktracker",
  "version": "1.0.10",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:web": "expo export --platform web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "seed:dev": "node --experimental-strip-types scripts/seed-dev.ts",
    "prepare": "husky",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k \"npm run web\" \"npm run electron:compile && electron electron/main.js\"",
    "electron:build": "npm run build:web && npm run electron:compile",
    "electron:package": "npm run electron:build && electron-builder --config electron/electron-builder.yml",
    "electron:package:mac": "npm run electron:build && electron-builder --config electron/electron-builder.yml --mac",
    "electron:package:win": "npm run electron:build && electron-builder --config electron/electron-builder.yml --win",
    "electron:package:linux": "npm run electron:build && electron-builder --config electron/electron-builder.yml --linux",
    "electron:publish": "export $(grep GH_TOKEN .env | xargs) && npm run electron:build && electron-builder --config electron/electron-builder.yml --mac --publish always"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "electron-updater": "^6.8.3",
    "expo": "~55.0.5",
    "expo-constants": "^55.0.7",
    "expo-secure-store": "^55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0",
    "victory-native": "^36.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/json-schema": "^7.0.15",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^55.0.10",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
